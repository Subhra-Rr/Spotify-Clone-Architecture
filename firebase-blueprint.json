{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the MelodyStream app.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "PlaylistTrack": {
      "title": "PlaylistTrack",
      "description": "A track inside a user's playlist.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "artist": {
          "type": "string"
        },
        "album": {
          "type": "string"
        },
        "coverUrl": {
          "type": "string"
        },
        "audioUrl": {
          "type": "string"
        },
        "durationMs": {
          "type": "number"
        },
        "addedAt": {
          "type": "string"
        }
      },
      "required": ["title", "artist"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A customized playlist created by the user.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the playlist."
        },
        "coverUrl": {
          "type": "string",
          "description": "Optional cover image URL."
        },
        "tracks": {
          "type": "array",
          "items": {
            "$ref": "#/entities/PlaylistTrack"
          },
          "description": "The list of tracks belonging to this playlist."
        }
      },
      "required": ["name"]
    },
    "LikedSong": {
      "title": "LikedSong",
      "description": "A song that a user has liked.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "artist": {
          "type": "string"
        },
        "album": {
          "type": "string"
        },
        "coverUrl": {
          "type": "string"
        },
        "audioUrl": {
          "type": "string"
        },
        "durationMs": {
          "type": "number"
        },
        "likedAt": {
          "type": "string"
        }
      },
      "required": ["title", "artist"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A support ticket submitted by the user.",
      "type": "object",
      "properties": {
        "subject": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["subject", "message", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profile data."
    },
    "/users/{userId}/playlists/{playlistId}": {
      "schema": {
        "$ref": "#/entities/Playlist"
      },
      "description": "User-created playlists."
    },
    "/users/{userId}/likedSongs/{trackId}": {
      "schema": {
        "$ref": "#/entities/LikedSong"
      },
      "description": "Songs liked by the user."
    },
    "/users/{userId}/supportTickets/{ticketId}": {
      "schema": {
        "$ref": "#/entities/SupportTicket"
      },
      "description": "Support tickets submitted by the user."
    }
  }
}
